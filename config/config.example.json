{
  "server": {
    "host": "0.0.0.0",
    "port": 8000,
    "debug": true,
    "reload": true
  },
  "translation": {
    "engine": "mock",
    "supported_languages": [
      "manchu",
      "chinese"
    ],
    "max_text_length": 10000,
    "cache_enabled": true,
    "cache_ttl": 3600
  },
  "analysis": {
    "supported_types": [
      "morphology"
    ],
    "morphology": {
      "enable_caching": true,
      "cache_ttl": 3600
    }
  },
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
  },
  "api": {
    "title": "MCP Translation Server",
    "description": "满语-中文翻译和文本分析服务",
    "version": "1.0.0",
    "docs_url": "/docs",
    "redoc_url": "/redoc"
  },
  "security": {
    "enable_cors": true,
    "allowed_origins": [
      "*"
    ],
    "rate_limit": {
      "enabled": false,
      "requests_per_minute": 60
    }
  }
}
